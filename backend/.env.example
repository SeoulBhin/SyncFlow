# ===== SyncFlow Backend Environment =====
# 사용법:
#   1. 이 파일을 backend/.env 로 복사: cp backend/.env.example backend/.env
#   2. 아래 빈 값들을 각자 발급받은 키로 채우세요.
#   3. .env 는 .gitignore 에 등록되어 있어 git 에 커밋되지 않습니다.
#   4. 시크릿은 절대로 이 .env.example 에 직접 입력하지 마세요. (placeholder 만 유지)


# ---------- Server ----------
PORT=3000
NODE_ENV=development


# ---------- Database (PostgreSQL + pgvector) ----------
# docker-compose.yml 의 postgres 서비스와 일치해야 함.
# npm run docker:up 으로 컨테이너 실행 후 사용.
#
# ※ DATABASE_HOST/PORT/USERNAME/PASSWORD/NAME 은 NestJS(TypeORM) 가 사용.
# ※ DATABASE_URL 은 Prisma 마이그레이션이 사용 (prisma.config.ts 가 backend/.env 를 읽음).
#   두 설정이 같은 PostgreSQL 인스턴스를 가리키도록 일치시킬 것.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=syncflow
DATABASE_PASSWORD=syncflow1234
DATABASE_NAME=syncflow

# Prisma 용 — 위 DATABASE_* 값들과 일치시킬 것.
# 형식: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://syncflow:syncflow1234@localhost:5432/syncflow?schema=public


# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379


# ---------- JWT ----------
# 비워두면 fallback (dev-secret / dev-refresh-secret) 으로 동작은 하지만,
# 팀원마다 .env 값이 다르면 토큰 검증이 깨져 401 (토큰 인증 오류) 가 발생한다.
# 팀에서 공용으로 한 값을 정해 모두 동일하게 채울 것.
# 개발 중에는 아무 문자열이라도 통일만 되면 OK. 운영은 충분히 긴 랜덤.
# 생성 예시: openssl rand -hex 32
JWT_SECRET=dev-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d


# ---------- OAuth: Google ----------
# 발급:    https://console.cloud.google.com/apis/credentials
# 콜백 URL: http://localhost:3000/api/auth/oauth/google/cb
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- OAuth: GitHub ----------
# 발급:    https://github.com/settings/developers
# 콜백 URL: http://localhost:3000/api/auth/oauth/github/cb
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- OAuth: Kakao ----------
# 발급:    https://developers.kakao.com/console/app
# 콜백 URL: http://localhost:3000/api/auth/oauth/kakao/cb
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=


# ---------- Google Cloud STT (회의 AI 킬러 피처) ----------
# 발급 절차:
#   1. GCP Console → IAM & Admin → Service Accounts → Create
#   2. Role: roles/speech.client (또는 roles/cloudspeech.serviceAgent)
#   3. Keys 탭 → Add Key → Create new key → JSON 다운로드
#   4. 다운받은 JSON 파일 전체 내용을 한 줄 문자열로 입력
#
# 형식 예시 (값은 각자 발급받은 것을 사용):
#   GOOGLE_STT_KEY_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}
#
# 참고: private_key 안의 \n 은 그대로 둬도 됨 (코드가 자동 변환).
GOOGLE_STT_KEY_JSON=


# ---------- Meeting STT: 오디오 업로드 ----------
# 절대경로 또는 process.cwd() 기준 상대경로
MEETING_AUDIO_DIR=uploads/audio
MEETING_AUDIO_MAX_MB=50


# ---------- Speech-to-Text 설정 ----------
STT_LANGUAGE=ko-KR
STT_MODEL=latest_long
STT_SAMPLE_RATE=48000
STT_MIN_SPEAKERS=2
STT_MAX_SPEAKERS=6


# ---------- AI: Gemini ----------
# 발급: https://aistudio.google.com/apikey
# 모델: https://ai.google.dev/gemini-api/docs/models (404 뜨면 교체)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ---------- Cloud Storage (GCS, 파일/이미지 업로드) ----------
# 인증은 GOOGLE_STT_KEY_JSON 의 서비스 계정을 재사용하거나 별도 키 사용.
# 버킷이 미리 생성되어 있어야 함.
GCS_BUCKET=syncflow-uploads


# ---------- LiveKit (음성/화상 회의) ----------
# backend/livekit.yaml 의 keys 섹션과 반드시 일치시킬 것.
#   - LIVEKIT_API_KEY    ↔  livekit.yaml 의 keys 항목 좌측 (예: devkey)
#   - LIVEKIT_API_SECRET ↔  livekit.yaml 의 keys 항목 우측 (예: devsecret-change-me-in-production)
# 운영 배포 시 강력한 랜덤 값으로 교체 필수.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-change-me-in-production


# ---------- URL ----------
# OAuth 콜백, 비밀번호 재설정 메일 등 절대 URL 생성에 사용.
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5174
