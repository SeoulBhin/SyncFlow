# ===== SyncFlow Backend Environment =====

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=syncflow
DATABASE_PASSWORD=your_password
DATABASE_NAME=syncflow

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Google Cloud (STT) — 서비스 계정 JSON 전체를 한 줄 문자열로 입력.
# 예: GOOGLE_STT_KEY_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com",...}
# private_key 안의 개행은 \n 으로 이스케이프된 채 둬도 됨 — 코드가 자동 변환함.
GOOGLE_STT_KEY_JSON=

# Meeting STT — 오디오 업로드 저장 경로 (절대경로 또는 process.cwd() 기준 상대경로)
MEETING_AUDIO_DIR=uploads/audio
MEETING_AUDIO_MAX_MB=50

# Speech-to-Text 설정
STT_LANGUAGE=ko-KR
STT_MODEL=latest_long
STT_SAMPLE_RATE=48000
STT_MIN_SPEAKERS=2
STT_MAX_SPEAKERS=6

# AI (Gemini)
GEMINI_API_KEY=
# 모델 라인업이 자주 바뀜 — 404가 뜨면 https://ai.google.dev/gemini-api/docs/models 참고해 교체
GEMINI_MODEL=gemini-2.5-flash

# Cloud Storage (GCS)
GCS_BUCKET=syncflow-uploads

# LiveKit (livekit.yaml 의 keys 섹션과 일치해야 함)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-change-me-in-production

# Backend & Frontend URL
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5174
