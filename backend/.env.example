# ===== SyncFlow Backend Environment =====

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=syncflow
DATABASE_PASSWORD=your_password
DATABASE_NAME=syncflow

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# AI (Gemini)
GEMINI_API_KEY=

# Cloud Storage (GCS)
GCS_BUCKET=syncflow-uploads

# LiveKit (livekit.yaml 의 keys 섹션과 일치해야 함)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-change-me-in-production

# Backend & Frontend URL
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5174
