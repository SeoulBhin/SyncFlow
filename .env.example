# SyncFlow 프론트엔드 환경변수
# Vite dev server가 /api → http://localhost:3000 으로 프록시하므로
# 개발 시에는 별도 설정 불필요합니다.

# 프로덕션 배포 시 백엔드 API 주소 (선택)
VITE_API_URL=http://localhost:3000

# Hocuspocus 실시간 협업 서버 WebSocket URL
# 기본값: ws://localhost:1234 (backend DocumentService.onModuleInit에서 자동 시작)
VITE_HOCUSPOCUS_URL=ws://localhost:1234
