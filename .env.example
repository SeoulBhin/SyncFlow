# ==================================================================
# SyncFlow 루트 환경변수 (.env.example)
# ==================================================================
# 사용법:
#   1. 이 파일을 .env 로 복사:    cp .env.example .env
#   2. 아래 변수들이 필요하면 채우세요. 개발 시에는 비워둬도 됩니다.
#
# ⚠️  중요:
#   - 백엔드(NestJS) 환경변수는 별도 파일입니다: backend/.env (backend/.env.example 참고)
#   - Prisma 마이그레이션의 DATABASE_URL 도 backend/.env 에 있습니다.
#     (prisma.config.ts 가 backend/.env 를 읽도록 설정되어 있음)
#   - 이 루트 .env 는 Vite 프론트엔드 빌드 환경변수만 담습니다.
# ==================================================================


# ---------- Vite 프론트엔드 ----------
# 개발 시: vite.config.ts 의 프록시가 /api → http://localhost:3000 자동 처리하므로 비워둬도 됩니다.
# 프로덕션 배포 시: 실제 백엔드 도메인으로 교체.
VITE_API_URL=http://localhost:3000

# Hocuspocus 실시간 협업 서버 WebSocket URL
# 기본값: ws://localhost:1234 (backend DocumentService.onModuleInit 에서 자동 시작)
VITE_HOCUSPOCUS_URL=ws://localhost:1234
