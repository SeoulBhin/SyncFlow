generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgcrypto, vector] // pgcrypto와 pgvector 확장 활성화
}

// 1. Users (최상위 테이블)
model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique @db.VarChar(255)
  passwordHash  String?  @map("password_hash") @db.VarChar(255)
  name          String   @db.VarChar(100)
  avatarUrl     String?  @map("avatar_url")
  statusMessage String?  @map("status_message") @db.VarChar(200)
  role          String   @default("member") @db.VarChar(20) // admin, member, tester
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  oauthAccounts   OauthAccount[]
  settings        UserSetting?
  ownedGroups     Group[]           @relation("CreatedGroups")
  groupMembers    GroupMember[]
  projectMembers  ProjectMember[]
  pages           Page[]
  pageVersions    PageVersion[]
  assignedTasks   Task[]            @relation("AssignedTasks")
  createdTasks    Task[]            @relation("CreatedTasks")
  schedules       Schedule[]
  channelMembers  ChannelMember[]
  messages        Message[]
  messageReactions MessageReaction[]
  aiConversations AiConversation[]
  subscriptions   Subscription[]
  payments        Payment[]
  notifications   Notification[]
  fileUploads     FileUpload[]

  @@index([email])
  @@map("users")
}

// 2. OAuth Accounts
model OauthAccount {
  id            Int      @id @default(autoincrement())
  userId        String   @map("user_id") @db.Uuid
  provider      String   @db.VarChar(20) // google, github, kakao
  providerId    String   @map("provider_id") @db.VarChar(255)
  providerEmail       String?  @map("provider_email") @db.VarChar(255)
  providerAccessToken String?  @map("provider_access_token") @db.Text
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("oauth_accounts")
}

// 3. User Settings
model UserSetting {
  id             Int      @id @default(autoincrement())
  userId         String   @unique @map("user_id") @db.Uuid
  theme          String   @default("system") @db.VarChar(10)
  notifyMessage  Boolean  @default(true) @map("notify_message")
  notifyTask     Boolean  @default(true) @map("notify_task")
  notifyDeadline Boolean  @default(false) @map("notify_deadline")
  notifyBrowser  Boolean  @default(true) @map("notify_browser")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// 4. Groups
model Group {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @db.VarChar(100)
  description     String?
  visibility      String   @default("public") @db.VarChar(10)
  isExternal      Boolean  @default(false) @map("is_external")
  connectedOrgIds String[] @default([]) @map("connected_org_ids") @db.Uuid
  createdBy       String   @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  creator      User          @relation("CreatedGroups", fields: [createdBy], references: [id])
  members      GroupMember[]
  inviteCodes  InviteCode[]
  projects     Project[]
  channels     Channel[]

  @@map("groups")
}

// 5. Group Members
model GroupMember {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id") @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  role      String   @default("member") @db.VarChar(20)
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

// 6. Invite Codes
model InviteCode {
  id        Int       @id @default(autoincrement())
  groupId   String    @map("group_id") @db.Uuid
  code      String    @unique @db.VarChar(8)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  expiresAt DateTime? @map("expires_at") @db.Timestamptz

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([code])
  @@map("invite_codes")
}

// 7. Projects
model Project {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId     String   @map("group_id") @db.Uuid
  name        String   @db.VarChar(200)
  description String?
  deadline    DateTime? @db.Date
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  group           Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  members         ProjectMember[]
  pages           Page[]
  tasks           Task[]
  schedules       Schedule[]
  channels        Channel[]
  aiConversations AiConversation[]

  @@index([groupId])
  @@map("projects")
}

// 8. Project Members
model ProjectMember {
  id        Int      @id @default(autoincrement())
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @default("viewer") @db.VarChar(20)
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

// 9. Pages
model Page {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  title       String   @db.VarChar(300)
  type        String   @db.VarChar(10) // document, code
  content     Json?
  language    String?  @db.VarChar(20)
  sortOrder   Int      @default(0) @map("sort_order")
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator     User          @relation(fields: [createdBy], references: [id])
  versions    PageVersion[]
  embeddings  Embedding[]
  fileUploads FileUpload[]

  @@index([projectId])
  @@map("pages")
}

// 10. Page Versions
model PageVersion {
  id        Int      @id @default(autoincrement())
  pageId    String   @map("page_id") @db.Uuid
  content   Json
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  page    Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  creator User @relation(fields: [createdBy], references: [id])

  @@index([pageId])
  @@map("page_versions")
}

// 11. Tasks
model Task {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId          String?   @map("project_id") @db.Uuid
  title              String    @db.VarChar(300)
  description        String?
  status             String    @default("todo") @db.VarChar(20)
  priority           String    @default("medium") @db.VarChar(10)
  assigneeId         String?   @map("assignee_id") @db.Uuid
  assignee           String?   @db.VarChar(100)
  dueDate            DateTime? @map("due_date") @db.Date
  sortOrder          Int       @default(0) @map("sort_order")
  sourceMeetingId    String?   @map("source_meeting_id") @db.Uuid
  sourceActionItemId String?   @map("source_action_item_id") @db.Uuid
  createdBy          String?   @map("created_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeUser User? @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator   User?    @relation("CreatedTasks", fields: [createdBy], references: [id])

  @@index([projectId])
  @@index([assigneeId])
  @@index([sourceMeetingId])
  @@map("tasks")
}

// 12. Schedules
model Schedule {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  title       String   @db.VarChar(300)
  startDate   DateTime @map("start_date") @db.Timestamptz
  endDate     DateTime @map("end_date") @db.Timestamptz
  allDay      Boolean  @default(false) @map("all_day")
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id])

  @@index([projectId])
  @@map("schedules")
}

// 13. Channels
model Channel {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId     String   @map("group_id") @db.Uuid
  projectId   String?  @map("project_id") @db.Uuid
  type        String   @db.VarChar(10) // group, project, dm
  name        String?  @db.VarChar(100)
  description String?
  inviteCode  String?  @unique @map("invite_code") @db.VarChar(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  group    Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  project  Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members  ChannelMember[]
  messages Message[]

  @@index([groupId])
  @@map("channels")
}

// 14. Channel Members
model ChannelMember {
  id         Int       @id @default(autoincrement())
  channelId  String    @map("channel_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  userName   String    @default("") @map("user_name") @db.VarChar(100)
  lastReadAt DateTime? @map("last_read_at") @db.Timestamptz
  joinedAt   DateTime  @default(now()) @map("joined_at") @db.Timestamptz

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("channel_members")
}

// 15. Messages
model Message {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channelId  String   @map("channel_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  authorName String   @default("") @map("author_name") @db.VarChar(100)
  content    String   @db.Text
  type       String   @default("text") @db.VarChar(10)
  fileUrl    String?  @map("file_url")
  isEdited   Boolean  @default(false) @map("is_edited")
  isSystem   Boolean  @default(false) @map("is_system")
  replyCount Int      @default(0) @map("reply_count")
  parentId   String?  @map("parent_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  channel     Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id])
  parent      Message?          @relation("Replies", fields: [parentId], references: [id], onDelete: SetNull)
  replies     Message[]         @relation("Replies")
  reactions   MessageReaction[]
  fileUploads FileUpload[]

  @@index([channelId, createdAt])
  @@map("messages")
}

// 16. Message Reactions
model MessageReaction {
  id        Int      @id @default(autoincrement())
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String   @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("message_reactions")
}

// 17. Meetings
model Meeting {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String    @db.VarChar(200)
  groupId    String?   @map("group_id") @db.Uuid
  projectId  String?   @map("project_id") @db.Uuid
  hostId     String?   @map("host_id") @db.Uuid
  status     String    @default("scheduled") @db.VarChar(20)
  visibility String    @default("private") @db.VarChar(10)
  startedAt  DateTime? @map("started_at") @db.Timestamptz
  endedAt    DateTime? @map("ended_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  transcripts  MeetingTranscript[]
  summary      MeetingSummary?
  actionItems  MeetingActionItem[]
  participants MeetingParticipant[]

  @@map("meetings")
}

// 18. Meeting Participants
model MeetingParticipant {
  id        Int      @id @default(autoincrement())
  meetingId String   @map("meeting_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  userName  String   @default("") @map("user_name") @db.VarChar(100)
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
  @@map("meeting_participants")
}

// 19. Meeting Transcripts (STT 결과)
model MeetingTranscript {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meetingId String   @map("meeting_id") @db.Uuid
  text      String   @db.Text
  speaker   String?  @db.VarChar(100)
  startTime Float?   @map("start_time")
  endTime   Float?   @map("end_time")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("meeting_transcripts")
}

// 20. Meeting Summaries (AI 요약)
model MeetingSummary {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meetingId String   @unique @map("meeting_id") @db.Uuid
  summary   String   @db.Text
  keywords  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_summaries")
}

// 21. Meeting Action Items
model MeetingActionItem {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meetingId String    @map("meeting_id") @db.Uuid
  title     String    @db.VarChar(300)
  assignee  String?   @db.VarChar(100)
  dueDate   DateTime? @map("due_date") @db.Date
  confirmed Boolean   @default(false)
  taskId    String?   @map("task_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("meeting_action_items")
}

// 22. AI Conversations
model AiConversation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  projectId String?  @map("project_id") @db.Uuid
  title     String   @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages AiMessage[]

  @@index([userId])
  @@map("ai_conversations")
}

// 23. AI Messages
model AiMessage {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId  String   @map("conversation_id") @db.Uuid
  role            String   @db.VarChar(10)
  content         String   @db.Text
  referencedFiles String[] @map("referenced_files")
  tokensUsed      Int?     @map("tokens_used")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

// 24. Embeddings (pgvector 중요 필드)
model Embedding {
  id         Int                    @id @default(autoincrement())
  pageId     String                 @map("page_id") @db.Uuid
  chunkIndex Int                    @map("chunk_index")
  content    String                 @db.Text
  vector     Unsupported("vector(768)") // pgvector 타입 설정
  metadata   Json?
  createdAt  DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@map("embeddings")
}

// 25. Subscriptions
model Subscription {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  plan               String    @default("free") @db.VarChar(10)
  status             String    @default("active") @db.VarChar(15)
  period             String?   @db.VarChar(10)
  currentPeriodStart DateTime? @map("current_period_start") @db.Timestamptz
  currentPeriodEnd   DateTime? @map("current_period_end") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([userId])
  @@map("subscriptions")
}

// 26. Payments
model Payment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  subscriptionId  String?  @map("subscription_id") @db.Uuid
  amount          Int
  currency        String   @default("KRW") @db.VarChar(3)
  status          String   @db.VarChar(10)
  method          String?  @db.VarChar(50)
  description     String?  @db.VarChar(200)
  pgTransactionId String?  @map("pg_transaction_id") @db.VarChar(100)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@map("payments")
}

// 27. Notifications
model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(20)
  title     String   @db.VarChar(200)
  content   String?  @db.Text
  link      String?  @db.VarChar(500)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

// 28. File Uploads
model FileUpload {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  originalName String   @map("original_name") @db.VarChar(300)
  storedPath   String   @map("stored_path")
  mimeType     String?  @map("mime_type") @db.VarChar(100)
  sizeBytes    BigInt   @map("size_bytes")
  pageId       String?  @map("page_id") @db.Uuid
  messageId    String?  @map("message_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user    User     @relation(fields: [userId], references: [id])
  page    Page?    @relation(fields: [pageId], references: [id], onDelete: SetNull)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([pageId])
  @@map("file_uploads")
}